datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model GithubStory {
  id             String   @id @default(uuid())
  username       String   @unique
  name           String?
  avatarUrl      String
  bio            String?
  stats          String   // JSON string of aggregated stats
  storyText      String   // Generated developer story narrative
  archetype      String
  level          Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Comparison {
  id        String   @id @default(uuid())
  userA     String
  userB     String
  data      String   // JSON of comparisons
  createdAt DateTime @default(now())
}
